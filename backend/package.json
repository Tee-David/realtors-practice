    "helmet": "^8.1.0",
    "meilisearch": "^0.44.0",
    "prisma": "^5.22.0",
    "resend": "^4.0.0",
    "socket.io": "^4.8.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
